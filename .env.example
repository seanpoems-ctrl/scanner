# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your real secrets.

# URL of your Render backend (no trailing slash).
RENDER_URL=https://scanner-gules-rho.onrender.com

# Shared secret between local_pusher.py and Render.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# Set the SAME value in Render > Environment > PUSH_SECRET.
PUSH_SECRET=replace_me_with_a_random_secret
